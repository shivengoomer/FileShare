<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="">
    <system.webServer>
      <!-- FastAPI reverse proxy via HTTP Platform Handler -->
      <httpPlatform processPath="python" arguments="-m uvicorn backend.main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT%" startupTimeLimit="60" rapidFailsPerMinute="10" requestTimeout="00:04:00">
        <environmentVariables>
          <environmentVariable name="PYTHONUNBUFFERED" value="true" />
          <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        </environmentVariables>
      </httpPlatform>

      <!-- Allow large file uploads for chunked uploads -->
      <security>
        <requestFiltering>
          <requestLimits maxUrl="10485760" maxAllowedContentLength="104857600" />
        </requestFiltering>
      </security>

      <!-- WebSocket support -->
      <webSocket enabled="true" />

      <!-- Rewrite rules to ensure requests reach FastAPI -->
      <rewrite>
        <rules>
          <rule name="StaticAssets" stopProcessing="true">
            <match url="^/assets/" />
            <action type="None" />
          </rule>
          <rule name="ReverseProxyInboundRule1" stopProcessing="true">
            <match url="(.*)" />
            <conditions>
              <add input="{HTTP_HOST}" pattern="localhost" negate="true" />
            </conditions>
            <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
          </rule>
        </rules>
      </rewrite>
    </system.webServer>
  </location>
</configuration>
